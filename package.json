{
  "name": "labellens",
  "version": "0.1.0",
  "private": true,
  "description": "LabelLens mobile-first PWA: scanner de productos, calculadora de menus por gramos y perfil nutricional.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier . --write",
    "check": "npm run lint && npm run test && npm run build",
    "compose:up": "docker compose -f infra/compose/docker-compose.yml up --wait --wait-timeout 180",
    "compose:down": "docker compose -f infra/compose/docker-compose.yml down",
    "compose:ps": "docker compose -f infra/compose/docker-compose.yml ps",
    "export": "powershell -ExecutionPolicy Bypass -File scripts/export-repo.ps1",
    "dev:web": "npm run dev -w apps/web",
    "dev:gateway": "npm run dev -w @labellens/gateway",
    "build:domain": "npm run build -w @labellens/domain",
    "build:gateway": "npm run build -w @labellens/gateway",
    "build:web": "npm run build -w web",
    "build:infrastructure": "npm run build -w @labellens/infrastructure",
    "compose:logs:gateway": "docker compose -f infra/compose/docker-compose.yml logs -f gateway",
    "compose:logs:localstack": "docker compose -f infra/compose/docker-compose.yml logs -f localstack",
    "local:init": "powershell -ExecutionPolicy Bypass -File infra/local/init-localstack.ps1",
    "local:persistence:smoke": "powershell -ExecutionPolicy Bypass -File infra/local/smoke-local-persistence.ps1",
    "compose:logs:web": "docker compose -f infra/compose/docker-compose.yml logs -f web",
    "local:resources:check": "powershell -ExecutionPolicy Bypass -File infra/local/check-local-resources.ps1",
    "build:contracts": "npm run build -w @labellens/contracts",
    "generate:openapi": "npm run build:contracts && npm run generate:openapi -w @labellens/contracts",
    "check:openapi": "npm run build:contracts && npm run check:openapi -w @labellens/contracts",
    "test:gateway": "npm run test -w @labellens/gateway",
    "dev:auth-service": "npm run dev -w @labellens/auth-service",
    "dev:food-service": "npm run dev -w @labellens/food-service",
    "dev:product-service": "npm run dev -w @labellens/product-service",
    "dev:menu-service": "npm run dev -w @labellens/menu-service",
    "dev:favorites-service": "npm run dev -w @labellens/favorites-service",
    "build:service-support": "npm run build -w @labellens/service-support",
    "build:auth-service": "npm run build -w @labellens/auth-service",
    "build:food-service": "npm run build -w @labellens/food-service",
    "build:product-service": "npm run build -w @labellens/product-service",
    "build:menu-service": "npm run build -w @labellens/menu-service",
    "build:favorites-service": "npm run build -w @labellens/favorites-service",
    "build:services": "npm run build:service-support && npm run build:auth-service && npm run build:food-service && npm run build:product-service && npm run build:menu-service && npm run build:favorites-service",
    "build:api": "npm run build:services",
    "test:auth-service": "npm run test -w @labellens/auth-service",
    "test:food-service": "npm run test -w @labellens/food-service",
    "test:product-service": "npm run test -w @labellens/product-service",
    "test:menu-service": "npm run test -w @labellens/menu-service",
    "test:favorites-service": "npm run test -w @labellens/favorites-service",
    "test:services": "npm run test:auth-service && npm run test:food-service && npm run test:product-service && npm run test:menu-service && npm run test:favorites-service",
    "compose:logs:auth-service": "docker compose -f infra/compose/docker-compose.yml logs -f auth-service",
    "compose:logs:food-service": "docker compose -f infra/compose/docker-compose.yml logs -f food-service",
    "compose:logs:product-service": "docker compose -f infra/compose/docker-compose.yml logs -f product-service",
    "compose:logs:menu-service": "docker compose -f infra/compose/docker-compose.yml logs -f menu-service",
    "compose:logs:favorites-service": "docker compose -f infra/compose/docker-compose.yml logs -f favorites-service"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}